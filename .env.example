# Application
APP_ENV=development
LOG_LEVEL=info

# HTTP
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Webhook security
WEBHOOK_SIGNING_SECRET=change-me
WEBHOOK_REPLAY_WINDOW_SECONDS=300

# Persistence and queueing
DATABASE_URL=postgres://user:password@localhost:5432/security_webhook_router
REDIS_URL=redis://localhost:6379/0

# External provider credentials
PROVIDER_API_KEY=change-me
